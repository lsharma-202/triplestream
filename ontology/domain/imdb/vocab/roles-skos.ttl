PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX Vocabulary: <http://example.org/ontology/domain/imdb/vocab#>

<http://example.org/ontology/domain/imdb/vocab/roles>
    rdf:type owl:Ontology ;
    rdfs:label "IMDb Profession Vocabulary"@en ;
    owl:versionInfo "v0.1.0" ;
    dcterms:description "Flat SKOS ConceptScheme of 44 IMDb profession values derived from the primaryProfession field in name.basics.tsv.gz. Concepts are used as object values for core:hasProfession and validated by shapes/domain/imdb/imdb-roles.shapes.ttl."@en ;
    dcterms:source <https://developer.imdb.com/non-commercial-datasets/> .

vocab:ProfessionScheme
   rdf:type skos:ConceptScheme ;
   skos:prefLabel "IMDb Professions"@en ;
   skos:definition "A controlled vocabulary of primary professions for individuals in the IMDb dataset."@en .

vocab:accountant
   rdf:type skos:Concept ;
   skos:prefLabel "Accountant"@en ;
   skos:inScheme vocab:ProfessionScheme .

