PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX vocab: <http://example.org/ontology/domain/imdb/vocab#>

<http://example.org/ontology/domain/imdb/vocab>
    rdf:type owl:Ontology ;
    rdfs:label "IMDb Genre Vocabulary"@en ;
    owl:versionInfo "v0.1.0" ;
    dcterms:description "Flat SKOS ConceptScheme of 28 IMDb genre values derived from the genres field in title.basics.tsv.gz. Concepts are used as object values for imdb:hasGenre."@en ;
    dcterms:source <https://developer.imdb.com/non-commercial-datasets/> .

vocab:GenreScheme
   rdf:type skos:ConceptScheme ;
   skos:prefLabel "IMDb Genres"@en ;
   skos:definition "A controlled vocabulary of genres for titles in the IMDb dataset."@en .

vocab:action
   rdf:type skos:Concept ;
   skos:prefLabel "Action"@en ;
   skos:inScheme vocab:GenreScheme .

